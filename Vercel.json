{
  "version": 2,
  "builds": [
    {
      "src": "api/redis.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/redis",
      "dest": "api/redis.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
